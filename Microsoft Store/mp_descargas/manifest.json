{
  "manifest_version": 3,
  "name": "MP Tools - Mercado Público (Compra Ágil)",
  "version": "4.4.0",
  "description": "Descarga masiva, carga masiva desde Excel, exportación de ofertas y resaltado de presupuestos para Mercado Público (Compra Ágil). Incluye descarga masiva de adjuntos en Licitaciones (Voucher View).",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MP Tools - Mercado Público",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.mercadopublico.cl/*"
      ],
      "js": [
        "content.js",
        "highlight_offers.js",
        "bulk_editor.js",
        "voucher_content.js",
        "licitaciones_download.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "api_interceptor.js"
      ],
      "matches": [
        "https://*.mercadopublico.cl/*"
      ]
    }
  ],
  "permissions": [
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://*.mercadopublico.cl/*"
  ]
}